{
  "name": "school-archive/wustl-news",
  "description": "Archived CSE 330 PHP news sharing assignment with unit tests and CI.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpstan/phpstan": "^2.1"
  },
  "autoload": {
    "files": [
      "src/NewsHelpers.php"
    ]
  },
  "autoload-dev": {
    "files": [
      "src/NewsHelpers.php"
    ]
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml",
    "test:coverage": "phpunit --configuration phpunit.xml --coverage-text",
    "analyse": "phpstan analyse --configuration phpstan.neon"
  }
}
